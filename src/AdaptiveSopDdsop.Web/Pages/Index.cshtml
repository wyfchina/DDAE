@page
@model IndexModel
@{
    ViewData["Title"] = "场景运行工作台";
}

<div id="scenario-workspace-app" class="app-shell">
    <aside id="primary-navigation" class="navigation" aria-label="主导航">
        <div class="brand-block">
            <div class="brand-mark" aria-hidden="true">DD</div>
            <div class="brand-copy">
                <strong>DDAE</strong>
                <span>需求驱动 S&OP 工作台</span>
            </div>
        </div>
        <nav class="nav-list">
            <a class="nav-item is-active" href="#overview-panel" data-help-key="overview"><span class="nav-index">01</span><span>总览</span></a>
            <a class="nav-item" href="#product-family-dashboard-panel" data-help-key="productFamilyDashboard"><span class="nav-index">02</span><span>产品族看板</span></a>
            <a class="nav-item" href="#data-readiness-panel" data-help-key="dataReadiness"><span class="nav-index">03</span><span>数据准备</span></a>
            <a class="nav-item" href="#variance-panel" data-help-key="exceptions"><span class="nav-index">04</span><span>异常识别</span></a>
            <a class="nav-item" href="#scenario-run-panel" data-help-key="scenarioRun"><span class="nav-index">05</span><span>场景运行</span></a>
            <a class="nav-item" href="#scenario-comparison" data-help-key="scenarioComparison"><span class="nav-index">06</span><span>方案比较</span></a>
            <a class="nav-item" href="#buffer-trend-panel" data-help-key="bufferTrend"><span class="nav-index">07</span><span>缓冲 / 库存趋势</span></a>
            <a class="nav-item" href="#rccp-panel" data-help-key="rccpConstraint"><span class="nav-index">08</span><span>RCCP 与约束</span></a>
            <a class="nav-item" href="#projected-supply-panel" data-help-key="supplierDemand"><span class="nav-index">09</span><span>供应商需求</span></a>
            <a class="nav-item" href="#saved-scenarios-panel" data-help-key="scenarioTrace"><span class="nav-index">10</span><span>场景留痕</span></a>
            <a class="nav-item" href="#master-settings-panel" data-help-key="masterSettings"><span class="nav-index">11</span><span>主设置治理</span></a>
            <a class="nav-item" href="#trace-panel" data-help-key="whiteBoxTrace"><span class="nav-index">12</span><span>白盒追踪</span></a>
            <a class="nav-item" href="#public-demo-golden-loop-panel" data-help-key="publicDemoGoldenLoop"><span class="nav-index">13</span><span>公开演示闭环</span></a>
        </nav>
        <div class="navigation-footer">
            <span class="service-dot" aria-hidden="true"></span>
            <span>本地数据源已连接</span>
        </div>
    </aside>

    <div class="application-area">
        <header class="top-context">
            <div class="top-context-leading">
                <button id="navigation-toggle" class="icon-button" type="button" aria-label="切换导航">&#9776;</button>
                <div class="factory-context">
                    <span class="context-label">计划范围</span>
                    <strong>卫星制造企业</strong>
                </div>
            </div>
            <div class="context-strip" aria-label="计划上下文">
                <div class="context-item">
                    <span class="context-label">主数据版本</span>
                    <strong id="master-data-version">演示数据-2026-06</strong>
                </div>
                <div class="context-item">
                    <span class="context-label">运行快照</span>
                    <strong id="snapshot-freshness">未加载</strong>
                </div>
                <div class="context-item">
                    <span class="context-label">系统健康</span>
                    <strong id="system-health" class="status-inline is-loading">检查中</strong>
                </div>
            </div>
            <div class="top-actions">
                <button id="refresh-workspace" class="button secondary" type="button">刷新</button>
                <div class="user-context">
                    <span class="user-avatar" aria-hidden="true">PL</span>
                    <span><strong>计划员</strong><small>计划角色</small></span>
                </div>
            </div>
        </header>

        <main id="workspace" class="workspace" tabindex="-1">
            <div class="page-heading">
                <div>
                    <p class="eyebrow">场景运行工作台</p>
                    <h1>需求驱动 S&OP 场景运行工作台</h1>
                    <p class="page-description">基于卫星制造基础数据，运行非持久化场景预览，比较基准方案与预览方案的影响。</p>
                </div>
                <span id="route-status" class="status-chip neutral">正在加载</span>
            </div>

            <section id="workspace-loading" class="readiness-banner is-loading" aria-live="polite">
                <div>
                    <span class="context-label">数据状态</span>
                    <strong>正在读取场景工作台数据</strong>
                    <p>当前阶段支持场景预览重算、候选动作组合选择、场景留痕和主设置变更治理。</p>
                </div>
            </section>

            <div id="workspace-error" class="persistent-error" role="alert" hidden>
                <strong>无法读取场景工作台数据</strong>
                <span id="workspace-error-message">请检查本地服务后刷新。</span>
            </div>

            <section id="overview-panel" class="workspace-section" hidden>
                <div id="workspace-kpis" class="schedule-kpis" aria-label="场景工作台关键指标"></div>
                <div id="network-structure-entry-card" class="network-product-entry">
                    <div class="panel-heading">
                        <div>
                            <span class="panel-kicker">独立产品入口</span>
                            <h2>网络结构评分</h2>
                        </div>
                        <a class="button secondary" href="@Model.NetworkStructureProductUrl">打开网络结构评分工作台</a>
                    </div>
                    <div class="readiness-banner">
                        <div>
                            <span class="context-label">跨产品协同</span>
                            <strong>网络结构评分已从 DDS&OP 主流程拆出</strong>
                            <p>网络结构评分独立读取已发布 BOM 快照、供应来源、资源路线、库存位置和缓冲设置，输出候选控制点、缓冲点、证据链与不采纳风险。</p>
                        </div>
                    </div>
                    <div class="metadata-grid">
                        <div class="metadata-card">
                            <span>从 DDS&OP 传入</span>
                            <strong>SKU / 产品族 / 周度运行上下文</strong>
                            <small>用于解释候选动作对服务、库存、RCCP 和供应风险的影响。</small>
                        </div>
                        <div class="metadata-card">
                            <span>网络评分返回</span>
                            <strong>候选建议 + 证据链</strong>
                            <small>候选进入 DDS&OP 后仍需通过白盒场景预览重新验证。</small>
                        </div>
                        <div class="metadata-card">
                            <span>求解器边界</span>
                            <strong>只选择候选动作组合</strong>
                            <small>Gurobi / OR-Tools 不生成计划，不自动采纳、不保存、不审批。</small>
                        </div>
                    </div>
                </div>
            </section>

            <section id="public-demo-golden-loop-panel" class="workspace-section" hidden>
                <div class="panel-heading">
                    <div>
                        <span class="panel-kicker">Controlled Contract Golden Loop Demo</span>
                        <h2>PUBLIC-DEMO-GOLDEN-DATA-V1 公开演示闭环</h2>
                    </div>
                    <div class="panel-inline-actions">
                        <span id="public-demo-package-chip" class="status-chip neutral">等待读取</span>
                        <button id="refresh-public-demo" class="button secondary" type="button">刷新演示包</button>
                        <button id="write-public-demo-payload" class="button primary" type="button">生成并写出配置 payload</button>
                    </div>
                </div>
                <div class="readiness-banner">
                    <div>
                        <span class="context-label">演示边界</span>
                        <strong>DemoFixture / ReviewedEvidence / Controlled Contract Golden Loop Demo / MappingConfidence = PublicDemoOnly</strong>
                        <p>本区只用于文件化公开演示包的受控契约闭环，不代表 ProductionValidated、Business Golden Loop readiness 或生产权威。</p>
                    </div>
                </div>
                <div id="public-demo-kpis" class="rccp-kpis" aria-label="公开演示闭环关键状态"></div>
                <div class="public-demo-grid">
                    <section class="public-demo-card">
                        <div class="panel-heading compact-heading">
                            <div><span class="panel-kicker">数据包</span><h2>文件化数据包与行数</h2></div>
                        </div>
                        <div id="public-demo-package-summary" class="metadata-list"></div>
                        <div class="table-scroll">
                            <table class="data-table">
                                <thead><tr><th>文件</th><th>角色</th><th>行数</th><th>校验摘要</th></tr></thead>
                                <tbody id="public-demo-package-file-body"></tbody>
                            </table>
                        </div>
                    </section>
                    <section class="public-demo-card">
                        <div class="panel-heading compact-heading">
                            <div><span class="panel-kicker">Reviewed mappings</span><h2>受控候选映射</h2></div>
                        </div>
                        <div class="table-scroll">
                            <table class="data-table">
                                <thead><tr><th>对象</th><th>边界</th><th>允许用途</th><th>禁止用途</th></tr></thead>
                                <tbody id="public-demo-mapping-body"></tbody>
                            </table>
                        </div>
                    </section>
                    <section class="public-demo-card">
                        <div class="panel-heading compact-heading">
                            <div><span class="panel-kicker">排程治理</span><h2>排程治理与适配器审计</h2></div>
                            <span id="public-demo-adapter-chip" class="status-chip is-paused">非 DDAE 执行权威</span>
                        </div>
                        <div id="public-demo-scheduling-governance" class="metadata-list"></div>
                        <div class="table-scroll">
                            <table class="data-table">
                                <thead><tr><th>字段</th><th>值</th><th>主责</th><th>DDAE 用途</th><th>禁止用途</th></tr></thead>
                                <tbody id="public-demo-adapter-metadata-body"></tbody>
                            </table>
                        </div>
                        <div id="public-demo-adapter-boundary-list" class="diagnostics-list"></div>
                    </section>
                    <section class="public-demo-card">
                        <div class="panel-heading compact-heading">
                            <div><span class="panel-kicker">DDAE -> SDBR</span><h2>DDSOP-CONFIG-INBOUND-V1 payload</h2></div>
                            <span id="public-demo-handoff-chip" class="status-chip neutral">未写出</span>
                        </div>
                        <div id="public-demo-payload-summary" class="metadata-list"></div>
                        <div class="payload-columns">
                            <div>
                                <h3>OperatingModelConfiguration</h3>
                                <pre id="public-demo-operating-model" class="json-preview"></pre>
                            </div>
                            <div>
                                <h3>SchedulingConfiguration</h3>
                                <pre id="public-demo-scheduling" class="json-preview"></pre>
                            </div>
                            <div>
                                <h3>DDMRPConfiguration</h3>
                                <pre id="public-demo-ddmrp" class="json-preview"></pre>
                            </div>
                        </div>
                    </section>
                    <section class="public-demo-card">
                        <div class="panel-heading compact-heading">
                            <div><span class="panel-kicker">SDBR -> DDAE</span><h2>反馈解释与偏差分析</h2></div>
                        </div>
                        <div class="table-scroll">
                            <table class="data-table">
                                <thead><tr><th>文件</th><th>状态</th><th>MessageID</th><th>Planning Run</th><th>OMC</th><th>冻结指纹</th><th>运行 / 求解</th><th>总体 / 偏差</th><th>映射置信</th><th>解释</th></tr></thead>
                                <tbody id="public-demo-feedback-body"></tbody>
                            </table>
                        </div>
                        <div id="public-demo-non-claims" class="diagnostics-list"></div>
                    </section>
                    <section id="public-demo-business-user-view" class="public-demo-card business-demo-card">
                        <div class="panel-heading compact-heading">
                            <div>
                                <span class="panel-kicker">业务用户演示视图</span>
                                <h2>从 DDS&OP 治理到 SDBR 评审反馈</h2>
                            </div>
                            <span class="status-chip neutral">PublicDemoOnly</span>
                        </div>
                        <p class="business-demo-lead">
                            这部分用业务语言说明同一条公开演示闭环：DDAE 负责批准和发布 DDS&OP 治理参数，SDBR 读取这些受控输入做演示级排程适配，并把结果作为评审反馈返回。
                        </p>
                        <div id="public-demo-business-summary" class="business-demo-flow" aria-label="公开演示闭环业务说明"></div>
                        <div id="public-demo-business-boundary" class="business-demo-boundary" aria-label="公开演示闭环业务边界"></div>
                    </section>
                </div>
            </section>

            <section id="product-family-dashboard-panel" class="workspace-section" hidden>
                <div class="panel-heading">
                    <div><span class="panel-kicker">管理层聚合视图</span><h2>产品族看板</h2></div>
                    <span id="product-family-case-chip" class="status-chip neutral">基准方案</span>
                </div>
                <div id="product-family-kpis" class="rccp-kpis" aria-label="产品族看板关键指标"></div>
                <div class="product-family-workbench">
                    <section class="product-family-block">
                        <div class="panel-heading compact-heading">
                            <div><span class="panel-kicker">产品族总览</span><h2>产品族卡片</h2></div>
                        </div>
                        <div id="product-family-card-grid" class="product-family-card-grid"></div>
                    </section>
                    <section class="product-family-block">
                        <div class="panel-heading compact-heading">
                            <div><span class="panel-kicker">周度风险网格</span><h2>产品族 × 周</h2></div>
                        </div>
                        <div id="product-family-weekly-grid" class="rccp-heatmap table-scroll" aria-label="产品族周度风险网格"></div>
                    </section>
                    <section id="product-family-detail-panel" class="product-family-detail">
                        <div class="panel-heading compact-heading">
                            <div><span class="panel-kicker">选中产品族详情</span><h2 id="product-family-selected-title">选中产品族详情</h2></div>
                        </div>
                        <div id="product-family-detail-summary" class="buffer-sku-metadata"></div>
                        <div class="rccp-detail-grid">
                            <div class="table-scroll"><table class="data-table"><thead><tr><th>范围</th><th>对象</th><th>周</th><th>原因</th><th>严重度</th></tr></thead><tbody id="product-family-risk-body"></tbody></table></div>
                            <div id="product-family-action-list" class="diagnostics-list"></div>
                        </div>
                        <div class="rccp-detail-grid">
                            <div class="table-scroll"><table class="data-table"><thead><tr><th>SKU</th><th>周</th><th>订单量</th><th>资源</th><th>资源负荷</th><th>触发</th></tr></thead><tbody id="product-family-rccp-body"></tbody></table></div>
                            <div class="table-scroll"><table class="data-table"><thead><tr><th>供应商</th><th>物料族</th><th>SKU</th><th>周</th><th>订单量</th><th>金额</th></tr></thead><tbody id="product-family-supply-body"></tbody></table></div>
                        </div>
                    </section>
                </div>
            </section>

            <section id="data-readiness-panel" class="workspace-section" hidden>
                <div class="result-context-bar" aria-label="筛选条件">
                    <label><span>产品族</span><select id="family-filter"></select></label>
                    <label><span>SKU</span><select id="sku-filter"></select></label>
                    <label><span>资源</span><select id="resource-filter"></select></label>
                    <label><span>供应风险</span><select id="risk-filter"></select></label>
                    <button id="clear-filters" class="button secondary" type="button">清除筛选</button>
                </div>
                <div class="readiness-grid">
                    <section class="readiness-panel">
                        <div class="panel-heading">
                            <div><span class="panel-kicker">主数据</span><h2>数据覆盖</h2></div>
                            <span id="data-status-chip" class="status-chip neutral">未加载</span>
                        </div>
                        <dl id="data-readiness-list" class="metadata-list"></dl>
                    </section>
                    <section class="readiness-panel">
                        <div class="panel-heading">
                            <div><span class="panel-kicker">业务栅栏</span><h2>采纳约束</h2></div>
                        </div>
                        <div class="table-scroll"><table class="data-table"><tbody id="guardrail-table-body"></tbody></table></div>
                    </section>
                    <section class="readiness-panel">
                        <div class="panel-heading">
                            <div><span class="panel-kicker">DDMRP 参数</span><h2>参数完整性</h2></div>
                            <div class="panel-inline-actions">
                                <button id="ddmrp-missing-only" class="button secondary compact-button" type="button" aria-pressed="false">仅看缺失</button>
                                <button id="ddmrp-toggle-all" class="button secondary compact-button" type="button" aria-expanded="false">查看全部</button>
                                <span id="ddmrp-completeness-chip" class="status-chip neutral">未检查</span>
                            </div>
                        </div>
                        <div class="table-scroll">
                            <table class="data-table">
                                <thead><tr><th>SKU</th><th>解耦点</th><th>缓冲档案</th><th>ADU / DAF</th><th>DLT / 变异</th><th>MOQ / 订货周期</th><th>区域调整</th><th>红 / 黄 / 绿上沿</th><th>状态</th></tr></thead>
                                <tbody id="ddmrp-parameter-body"></tbody>
                            </table>
                        </div>
                    </section>
                </div>
            </section>

            <section id="scenario-run-panel" class="workspace-section" hidden>
                <div class="panel-heading">
                    <div>
                        <span class="panel-kicker">场景配置</span>
                        <h2>运行预览</h2>
                    </div>
                    <span id="preview-persistence-chip" class="status-chip is-paused">预览结果，未保存</span>
                </div>
                <div class="scenario-run-layout">
                    <section class="scenario-config-panel">
                        <div class="form-grid compact">
                            <label><span>场景模板</span><select id="template-select"></select></label>
                            <label><span>采纳约束</span><select id="adoption-constraint-select">
                                <option value="Balanced">综合平衡</option>
                                <option value="ServiceFirst">服务优先</option>
                                <option value="FlowFirst">流速优先</option>
                                <option value="CashFirst">现金优先</option>
                                <option value="CapacityFirst">产能优先</option>
                                <option value="SupplyFirst">供应优先</option>
                            </select></label>
                            <label><span>目标 SKU</span><select id="preview-sku-select"></select></label>
                            <label><span>提前建库周</span><input id="prebuild-week" type="number" min="1" max="52" value="1"></label>
                            <label><span>提前建库数量</span><input id="prebuild-quantity" type="number" min="0" step="1" value="0"></label>
                            <label><span>产能资源</span><select id="capacity-resource-select"></select></label>
                            <label><span>产能调整周</span><input id="capacity-week" type="number" min="1" max="52" value="1"></label>
                            <label><span>能力倍率</span><input id="capacity-multiplier" type="number" min="0.1" max="3" step="0.05" value="1.00"></label>
                            <label><span>MOQ 覆盖值</span><input id="moq-override" type="number" min="0" step="1" value="0"></label>
                            <label><span>订货周期覆盖值</span><input id="order-cycle-override" type="number" min="1" max="60" step="1" value="1"></label>
                            <label><span>供应限制</span><select id="supplier-limit-select"></select></label>
                            <label><span>供应限制开始周</span><input id="supplier-limit-start-week" type="number" min="1" max="52" value="1"></label>
                            <label><span>供应限制结束周</span><input id="supplier-limit-end-week" type="number" min="1" max="52" value="12"></label>
                            <label><span>供应承诺能力</span><input id="supplier-capacity-limit" type="number" min="0" step="1" value="0"></label>
                        </div>
                        <div class="preview-actions">
                            <button id="run-preview" class="button primary" type="button">运行预览</button>
                            <span id="preview-status" class="status-chip neutral">尚未运行</span>
                        </div>
                        <div id="scenario-save-panel" class="scenario-save-panel" hidden>
                            <div class="panel-heading compact-heading">
                                <div><span class="panel-kicker">场景留痕</span><h2>保存场景</h2></div>
                                <span id="scenario-save-status" class="status-chip neutral">等待预览</span>
                            </div>
                            <div class="form-grid compact">
                                <label><span>场景名称</span><input id="scenario-save-name" type="text" maxlength="80" placeholder="例如：星载电子提前建库方案"></label>
                                <label><span>创建人</span><input id="scenario-save-created-by" type="text" maxlength="40" value="计划员"></label>
                                <label class="form-wide"><span>说明</span><input id="scenario-save-description" type="text" maxlength="240" placeholder="记录会议假设、约束来源或方案目的"></label>
                            </div>
                            <div class="preview-actions">
                                <button id="save-scenario" class="button secondary" type="button">保存场景</button>
                                <span class="muted-note">保存时后端会重新运行预览，并写入输入、输出、指标和 trace。</span>
                            </div>
                        </div>
                    </section>
                    <section>
                        <div class="panel-heading compact-heading">
                            <div><span class="panel-kicker">模板与动作</span><h2>可选模板</h2></div>
                        </div>
                        <div id="scenario-template-list" class="case-card-grid"></div>
                    </section>
                </div>
            </section>

            <section id="scenario-comparison" class="scenario-comparison workspace-section" hidden>
                <div class="panel-heading">
                    <div><span class="panel-kicker">基准方案与预览方案</span><h2>方案比较</h2></div>
                    <button id="generate-master-settings" class="button secondary" type="button">生成主设置变更建议</button>
                </div>
                <div id="scenario-comparison-result" class="comparison-grid"></div>
                <section id="multi-scenario-comparison-panel" class="budget-panel">
                    <div class="panel-heading compact-heading">
                        <div><span class="panel-kicker">多方案比较</span><h2>候选组合 KPI 对比</h2></div>
                    </div>
                    <div class="table-scroll">
                        <table class="data-table">
