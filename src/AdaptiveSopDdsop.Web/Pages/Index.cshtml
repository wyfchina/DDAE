@page
@model IndexModel
@{
    ViewData["Title"] = "Adaptive S&OP + DDS&OP";
}

<section class="hero">
    <div>
        <p class="eyebrow">Demand Driven Adaptive Enterprise</p>
        <h1>Adaptive S&amp;OP 与 DDS&amp;OP 实用决策驾驶舱</h1>
        <p class="hero-copy">
            面向 CEO 与 C-Level 的月度跨职能流程：上层管理 24-36 个月战略、财务和产品组合，
            中层 DDS&amp;OP 把战略翻译成 DDOM 主设置，并用真实运营反馈反向校验战略可行性。
        </p>
    </div>
    <div class="hero-panel">
        <span>当前教学模型</span>
        <strong>AS&amp;OP + DDS&amp;OP</strong>
        <small>4 个中文产品族、12 个 SKU、36 个月展望期、DDMRP 缓冲区与三性反馈验证数据</small>
    </div>
</section>

<section class="kpi-grid" id="kpiGrid"></section>

<section class="wide-section" id="processSection">
    <div class="section-head">
        <div>
            <p class="eyebrow">Single Game Plan</p>
            <h2>跨职能月度闭环</h2>
        </div>
        <span class="badge" id="horizonBadge">36 个月滚动展望</span>
    </div>
    <div class="module-grid two">
        <article>
            <h3>Adaptive S&amp;OP 高管流程</h3>
            <div class="table-wrap compact"><table><tbody id="asopStepsBody"></tbody></table></div>
        </article>
        <article>
            <h3>DDS&amp;OP 战术衔接 Hub</h3>
            <div class="table-wrap compact"><table><tbody id="ddsopElementsBody"></tbody></table></div>
        </article>
    </div>
</section>

<section class="wide-section" id="portfolioSection">
    <div class="section-head">
        <div>
            <p class="eyebrow">Portfolio / New Activities</p>
            <h2>产品组合、NPI 与退出治理</h2>
        </div>
        <span class="badge">每月第一步</span>
    </div>
    <div class="table-wrap"><table><tbody id="portfolioBody"></tbody></table></div>
</section>

<section class="wide-section" id="financialSection">
    <div class="section-head">
        <div>
            <p class="eyebrow">Monetized Plan</p>
            <h2>36 个月财务化投影</h2>
        </div>
        <span class="badge">收入 / 贡献毛利 / ROI / 现金缺口</span>
    </div>
    <div class="table-wrap"><table><tbody id="financialProjectionBody"></tbody></table></div>
</section>

<section class="wide-section" id="resourceSection">
    <div class="section-head">
        <div>
            <p class="eyebrow">Resource Profile / RRP</p>
            <h2>高层资源、供应商与资本可行性</h2>
        </div>
        <span class="badge">红黄绿约束</span>
    </div>
    <div class="module-grid three">
        <article>
            <h3>瓶颈资源剖面</h3>
            <div class="table-wrap compact"><table><tbody id="resourceProfileBody"></tbody></table></div>
        </article>
        <article>
            <h3>关键供应商约束</h3>
            <div class="table-wrap compact"><table><tbody id="supplierBody"></tbody></table></div>
        </article>
        <article>
            <h3>资本与固定成本边界</h3>
            <div class="table-wrap compact"><table><tbody id="capitalBody"></tbody></table></div>
        </article>
    </div>
</section>

<section class="wide-section" id="settingsSection">
    <div class="section-head">
        <div>
            <p class="eyebrow">Master Settings</p>
            <h2>DDOM 主设置、已知事件与能力缓冲</h2>
        </div>
        <span class="badge">替代传统远期 MPS</span>
    </div>
    <div class="module-grid three">
        <article>
            <h3>库存 / 时间 / 产能 / 解耦点设置</h3>
            <div class="table-wrap compact"><table><tbody id="masterSettingsBody"></tbody></table></div>
        </article>
        <article>
            <h3>已知事件与 DAF</h3>
            <div class="table-wrap compact"><table><tbody id="eventsBody"></tbody></table></div>
        </article>
        <article>
            <h3>技能与保护性能力</h3>
            <div class="table-wrap compact"><table><tbody id="skillBufferBody"></tbody></table></div>
        </article>
    </div>
</section>

<main class="workspace" id="scenarioSection">
    <aside class="process-panel">
        <div class="panel-title">
            <span>DDS&amp;OP 主设置</span>
            <strong>驾驶员视角</strong>
        </div>
        <ol class="steps">
            <li class="active"><b>1</b><span>读取真实 DDOM 偏差</span></li>
            <li><b>2</b><span>识别已知事件与外部变化</span></li>
            <li><b>3</b><span>调整 DAF / 区域调整因子</span></li>
            <li><b>4</b><span>配置库存、时间、产能缓冲</span></li>
            <li><b>5</b><span>形成战术机会或战略建议</span></li>
        </ol>
        <div class="doctrine">
            <strong>管理原则</strong>
            <p>DDAE 不把远期 MPS 当作战略流程的核心输出，而是维护解耦点与缓冲区主设置，让执行层由真实订单和 Net Flow Equation 拉动。</p>
        </div>
    </aside>

    <section class="scenario-card">
        <div class="section-head">
            <div>
                <p class="eyebrow">DDS&amp;OP Scenario Lab</p>
                <h2>战术情景与 DDMRP 缓冲投影</h2>
            </div>
            <button id="resetBtn" class="ghost-button" type="button">恢复基线</button>
        </div>

        <div class="control-grid">
            <label>
                <span>促销需求上调</span>
                <input id="promotionPercent" type="range" min="0" max="40" step="5" value="0" />
                <output id="promotionPercentOut">0%</output>
            </label>
            <label>
                <span>供应中断周数</span>
                <input id="supplyDisruptionWeeks" type="range" min="0" max="6" step="1" value="0" />
                <output id="supplyDisruptionWeeksOut">0 周</output>
            </label>
            <label>
                <span>计划停线天数</span>
                <input id="plannedShutdownDays" type="range" min="0" max="10" step="1" value="0" />
                <output id="plannedShutdownDaysOut">0 天</output>
            </label>
            <label>
                <span>新品周需求</span>
                <input id="newProductWeeklyDemand" type="range" min="0" max="600" step="50" value="0" />
                <output id="newProductWeeklyDemandOut">0</output>
            </label>
        </div>

        <div class="split-panels">
            <article>
                <h3>DDOM / DDMRP 缓冲投影</h3>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>SKU</th>
                                <th>ADU</th>
                                <th>状态</th>
                                <th>Net Flow</th>
                                <th>建议补货</th>
                                <th>现金占用</th>
                            </tr>
                        </thead>
                        <tbody id="skuProjectionBody"></tbody>
                    </table>
                </div>
            </article>
            <article>
                <h3>Management Review 行动建议</h3>
                <ul id="actionsList" class="actions"></ul>
            </article>
        </div>

        <article class="guardrail-panel">
            <div class="section-head">
                <div>
                    <p class="eyebrow">AS&amp;OP Guardrails</p>
                    <h3>授权栅栏校验</h3>
                </div>
                <span id="guardrailStatus" class="status">待计算</span>
            </div>
            <p id="guardrailDecision" class="guardrail-decision"></p>
            <div class="table-wrap compact">
                <table>
                    <tbody id="guardrailBody"></tbody>
                </table>
            </div>
        </article>
    </section>
</main>

<section class="wide-section" id="planRunSection">
    <div class="section-head">
        <div>
            <p class="eyebrow">White-box Plan Run</p>
            <h2>缓冲补货投影与需求驱动 RCCP</h2>
        </div>
        <span class="badge">Net Flow -> Order -> Capacity</span>
    </div>
    <div class="module-grid two">
        <article>
            <h3>Buffer Trend Graph</h3>
            <div class="table-wrap compact"><table><tbody id="bufferTrendBody"></tbody></table></div>
        </article>
        <article>
            <h3>Demand Driven RCCP</h3>
            <div class="table-wrap compact"><table><tbody id="rccpLoadBody"></tbody></table></div>
        </article>
        <article>
            <h3>Projected Supply Requirements</h3>
            <div class="table-wrap compact"><table><tbody id="supplyRequirementBody"></tbody></table></div>
        </article>
        <article>
            <h3>Calculation Trace</h3>
            <div class="table-wrap compact"><table><tbody id="planTraceBody"></tbody></table></div>
        </article>
    </div>
</section>

<section class="wide-section" id="feedbackSection">
    <div class="section-head">
        <div>
            <p class="eyebrow">DDOM Performance Feedback</p>
            <h2>可靠性、稳定性、流速偏差分析</h2>
        </div>
        <span class="badge">运行图 / 帕累托 / 例外频率</span>
    </div>
    <div class="module-grid two">
        <article>
            <h3>三性运行图</h3>
            <div class="table-wrap compact"><table><tbody id="feedbackBody"></tbody></table></div>
        </article>
        <article>
            <h3>根因帕累托</h3>
            <div id="paretoBody" class="bar-list"></div>
        </article>
    </div>
</section>

<section class="wide-section" id="decisionSection">
    <div class="section-head">
        <div>
            <p class="eyebrow">Strategic Adaptive Loop</p>
            <h2>战术机会、战略建议与远期可行性校验</h2>
        </div>
        <span class="badge">向上反馈给 AS&amp;OP</span>
    </div>
    <div class="module-grid three">
        <article>
            <h3>战术开拓</h3>
            <div class="table-wrap compact"><table><tbody id="tacticalOpportunityBody"></tbody></table></div>
        </article>
        <article>
            <h3>战略建议渠道</h3>
            <div class="table-wrap compact"><table><tbody id="strategicRecommendationBody"></tbody></table></div>
        </article>
        <article>
            <h3>运营可行性校验</h3>
            <div class="table-wrap compact"><table><tbody id="feasibilityBody"></tbody></table></div>
        </article>
    </div>
</section>

<section class="validation">
    <div class="section-head">
        <div>
            <p class="eyebrow">Auditable Data</p>
            <h2>基础验证数据</h2>
        </div>
        <span class="badge" id="dataBadge">验证数据</span>
    </div>
    <div class="validation-grid">
        <article>
            <h3>产品族</h3>
            <div class="table-wrap compact"><table><tbody id="familyBody"></tbody></table></div>
        </article>
        <article>
            <h3>周产能资源</h3>
            <div class="table-wrap compact"><table><tbody id="resourceBody"></tbody></table></div>
        </article>
        <article>
            <h3>SKU DDMRP 参数</h3>
            <div class="table-wrap compact"><table><tbody id="settingsBody"></tbody></table></div>
        </article>
    </div>
</section>

<script>
    window.initialScenarioResult = @Html.Raw(Model.InitialResultJson);
    window.validationData = @Html.Raw(Model.ValidationDataJson);
</script>
<script src="~/js/app.js" asp-append-version="true"></script>
